{# views/single-event.twig #}
{% extends "base.twig" %}

{% block content %}
  <article class="max-w-4xl mx-auto py-12 px-4">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-slate-900">{{ post.title }}</h1>
      
      {# If using ACF for structured data #}
      {% if post.meta('event_date') %}
        <div class="mt-4 flex items-center text-blue-600 font-semibold">
          <span>{{ post.meta('event_date')|date("F j, Y") }}</span>
        </div>
      {% endif %}
    </header>

    {% if post.thumbnail %}
      <img src="{{ post.thumbnail.src }}" class="w-full h-96 object-cover rounded-xl shadow-lg mb-8">
    {% endif %}

    <div class="prose prose-lg max-w-none">
      {{ post.content }}
    </div>
  </article>
{% endblock %}