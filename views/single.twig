{% extends "base.twig" %}

{% block content %}
<section class="py-16">
    <div class="container mx-auto px-4">
        <header class="mb-12">
            <h1 class="text-4xl/10 font-bold tracking-tight">Church News & Updates</h1>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for post in posts %}
                <article class="flex flex-col border border-gray-100 rounded-sm overflow-hidden shadow-xs hover:shadow-sm transition-shadow">
                    {% if post.thumbnail %}
                        <img src="{{ post.thumbnail.src }}" class="aspect-video object-cover" alt="{{ post.title }}">
                    {% endif %}
                    
                    <div class="p-6">
                        <h2 class="text-xl/7 font-bold mb-2">
                            <a href="{{ post.link }}" class="hover:text-blue-600">{{ post.title }}</a>
                        </h2>
                        <p class="text-gray-600 text-sm/6 line-clamp-3 mb-4">
                            {{ post.excerpt }}
                        </p>
                        <a href="{{ post.link }}" class="text-sm font-semibold text-blue-600">Read More &rarr;</a>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}