{% extends "base.twig" %}

{% block content %}

<section class="py-16 bg-gray-50 dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl/9 font-bold text-center mb-12 text-gray-900 dark:text-white">Our Ministries</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for ministry in theme.ministries %}
        <div class="flex flex-col bg-white dark:bg-gray-800 rounded-sm shadow-sm overflow-hidden border border-gray-100 dark:border-gray-700">
          
          {% if ministry.image %}
            <img src="{{ ministry.image }}" alt="{{ ministry.title }}" class="w-full h-48 object-cover">
          {% endif %}
          
          <div class="p-6 flex flex-col grow">
            <h3 class="text-xl/7 font-semibold text-gray-900 dark:text-white">{{ ministry.title }}</h3>
            
            {% if ministry.catchphrase %}
              <p class="text-sm/6 font-medium text-blue-600 dark:text-blue-400 mt-1 uppercase tracking-wider">
                {{ ministry.catchphrase }}
              </p>
            {% endif %}
            
            <p class="mt-4 text-gray-600 dark:text-gray-300 text-base/6">
              {{ ministry.details }}
            </p>
          </div>
          
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}