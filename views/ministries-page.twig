{% extends "base.twig" %}

{% block content %}
{# 1. Hero Section #}
<header class="relative min-h-[500px] flex items-center justify-center bg-gray-900 overflow-hidden">
    {% if theme.events.events_bg %}
        <img src="{{ theme.ministries_page.bg }}" 
            class="absolute inset-0 size-full object-cover opacity-60" 
             alt="{{ theme.ministries_page.title }}">
    {% endif %}

    <div class="relative text-center px-4">
        <h1 class="!text-white text-5xl md:text-7xl font-serif tracking-tight text-shadow-sm">
             {{ theme.ministries_page.title }}
        </h1>
        
        {# FIX: Added .events. before intro #}
        {% if theme.ministries_page.intro%}
            <p class="mt-4 text-white text-xl/7">{{ theme.ministries_page.intro }}</p>
        {% endif %}
    </div>
</header>
<div class="mx-auto max-w-4xl px-4 py-12">
<section class="">
  <div class="container mx-auto px-4">
    {# Main container limited to 3xl for a focused, readable layout #}
    <div class="flex flex-col gap-12 max-w-3xl mx-auto"> 
      
      {% for ministry in theme.ministries %}
        <article class="flex flex-col md:flex-row bg-white rounded-sm overflow-hidden shadow-sm border border-gray-100 md:h-64">
          
          {# Image Container: Fixed height on mobile, fills container height on desktop #}
          {% if ministry.image %}
            <div class="w-full md:w-2/5 shrink-0 h-48 md:h-full"> 
              <img 
                src="{{ ministry.image }}" 
                alt="{{ ministry.title }}" 
                class="size-full object-cover"
              >
            </div>
          {% endif %}
          
          {# Content Container: Scrollable if text exceeds fixed height #}
          <div class="pl-6 md:pl-8 mt-4 flex flex-col justify-center overflow-hidden">
            <header>
              <h2 class="text-2xl/8 font-bold text-gray-900  mb-2">
                {{ ministry.title }}
              </h2>
              {% if ministry.catchphrase %}
                <span class="block text-base/6 text-gray-500  tracking-widest mb-1">
                  {{ ministry.catchphrase }}
                </span>
              {% endif %}
            </header>
            
            {# Using line-height modifier text-base/6 per v4 rules #}
            <p class="text-gray-900 text-sm/6 md:text-base/6 clamp line-clamp-8">
              {{ ministry.details }}
            </p>
          </div>

        </article>
      {% endfor %}

    </div>
  </div>
</section>
</div>
{% endblock %}