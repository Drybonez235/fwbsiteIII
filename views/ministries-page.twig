{% extends "base.twig" %}

{% block content %}

<section class="py-16 bg-white dark:bg-gray-950">
  <div class="container mx-auto px-4">
    <div class="flex flex-col gap-12"> {# Large gap between rows #}
      
      {% for ministry in theme.ministries %}
        <article class="flex flex-col md:flex-row bg-gray-50 dark:bg-gray-900 rounded-sm overflow-hidden shadow-sm border border-gray-100 dark:border-gray-800">
          
          {# Image Container: Optimized for Landscape (16:9) #}
          {% if ministry.image %}
            <div class="w-full md:w-2/5 shrink-0"> {# Using shrink-0 to prevent flex compression #}
              <img 
                src="{{ ministry.image }}" 
                alt="{{ ministry.title }}" 
                class="w-full h-full object-cover aspect-video md:aspect-auto"
              >
            </div>
          {% endif %}
          
          {# Content Container #}
          <div class="p-8 flex flex-col justify-center">
            <header>
              {% if ministry.catchphrase %}
                <span class="block text-sm/5 font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">
                  {{ ministry.catchphrase }}
                </span>
              {% endif %}
              <h2 class="text-2xl/8 font-bold text-gray-900 dark:text-white mb-4">
                {{ ministry.title }}
              </h2>
            </header>
            
            <p class="text-gray-600 dark:text-gray-300 text-base/7 max-w-2xl">
              {{ ministry.details }}
            </p>
          </div>

        </article>
      {% endfor %}

    </div>
  </div>
</section>
{% endblock %}