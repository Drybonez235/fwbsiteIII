{% extends "base.twig" %}

{% block content %}
<main id="main-content">

  {# --- Hero Section --- #}
  <section class="relative">
    <div class="h-[500px] bg-cover bg-center flex items-center justify-center relative" 
         style="background-image: url('{{ theme.church_image }}');">
      <div class="absolute inset-0 bg-black/40"></div> {# Overlay #}
      <div class="relative z-10 text-center text-white px-6">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight drop-shadow-md">
          {{ theme.church_name }}
        </h1>
      </div>
    </div>

    {# --- Info Bar --- #}
    <div class="bg-blue-900 text-white py-6">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex flex-col md:flex-row gap-4 md:gap-8 text-center md:text-left">
          <p class="font-medium">Sunday School: <span class="font-bold text-blue-200">{{ function('get_theme_mod', 'sunday_school_time', '9:30 am') }}</span></p>
          <p class="font-medium">Worship: <span class="font-bold text-blue-200">{{ function('get_theme_mod', 'sunday_service_time', '11:00 am') }}</span></p>
        </div>
        <div class="text-center md:text-right">
          <p class="text-lg font-bold">{{ theme.church_phone }}</p>
          <p class="text-sm opacity-80">{{ theme.church_address }}</p>
        </div>
      </div>
    </div>
  </section>

  {# --- Mission Statement --- #}
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <blockquote class="mb-10">
        <p class="text-3xl md:text-4xl font-serif italic text-slate-800 leading-snug">
          "{{ function('get_theme_mod', 'homepage_mission_statement') }}"
        </p>
        <footer class="mt-6 text-blue-600 font-bold tracking-widest uppercase text-sm">
          — {{ function('get_theme_mod', 'mission_subtext') }}
        </footer>
      </blockquote>
      <a href="/about-us" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-full font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
        Learn More About our Beliefs
      </a>
    </div>
  </section>

  {# --- Service Times Section --- #}
  <section class="py-16 bg-slate-50 px-6">
    <div class="max-w-6xl mx-auto">
      
      {# Main Sunday Hero #}
      <div class="relative rounded-3xl overflow-hidden mb-12 shadow-2xl min-h-[400px] flex items-end">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ function('get_theme_mod', 'service_image') }}');"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
        
        <div class="relative p-8 md:p-12 text-white w-full">
          <h2 class="text-sm font-bold uppercase tracking-widest text-blue-400 mb-2">Worship at {{ theme.church_name }}</h2>
          <h3 class="text-4xl font-black mb-4">Sunday Worship</h3>
          <span class="inline-block bg-blue-600 px-4 py-1 rounded text-2xl font-bold mb-4">
            {{ function('get_theme_mod', 'sunday_service_time', '11:00 AM') }}
          </span>
          <p class="max-w-2xl text-slate-200 text-lg">
            {{ function('get_theme_mod', 'service_message') }}
          </p>
        </div>
      </div>

      {# Secondary Service Cards #}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        {# Sunday School Card #}
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between">
          <div>
            <h4 class="font-black text-blue-900 uppercase text-xs tracking-widest mb-4">Sunday School</h4>
            <p class="text-slate-600 text-sm mb-6">{{ function('get_theme_mod', 'sunday_school_description') }}</p>
          </div>
          <span class="text-2xl font-bold text-slate-900">{{ function('get_theme_mod', 'sunday_school_time', '9:30 AM') }}</span>
        </div>

        {# Sunday Service Card #}
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between">
          <div>
            <h4 class="font-black text-blue-900 uppercase text-xs tracking-widest mb-4">Sunday Service</h4>
            <p class="text-slate-600 text-sm mb-6">{{ function('get_theme_mod', 'sunday_service_description') }}</p>
          </div>
          <span class="text-2xl font-bold text-slate-900">{{ function('get_theme_mod', 'sunday_service_time', '11:00 AM') }}</span>
        </div>

        {# Sunday Night Card #}
        {% if function('get_theme_mod', 'enable_sunday_night') %}
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between">
          <div>
            <h4 class="font-black text-blue-900 uppercase text-xs tracking-widest mb-4">Sunday Night</h4>
            <p class="text-slate-600 text-sm mb-6">{{ function('get_theme_mod', 'sunday_night_description') }}</p>
          </div>
          <span class="text-2xl font-bold text-slate-900">{{ function('get_theme_mod', 'sunday_night_time', '6:00 PM') }}</span>
        </div>
        {% endif %}

        {# Wednesday Night Card #}
        {% if function('get_theme_mod', 'enable_wednesday_night') %}
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between">
          <div>
            <h4 class="font-black text-blue-900 uppercase text-xs tracking-widest mb-4">Wednesday Night</h4>
            <p class="text-slate-600 text-sm mb-6">{{ function('get_theme_mod', 'wednesday_night_description') }}</p>
          </div>
          <span class="text-2xl font-bold text-slate-900">{{ function('get_theme_mod', 'wednesday_night_time', '6:00 PM') }}</span>
        </div>
        {% endif %}

      </div>
    </div>
  </section>

  {# --- Pastor Section --- #}
  <section class="py-20 bg-white px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="w-full md:w-1/3">
        {% if function('get_theme_mod', 'pastor_image') %}
          <img src="{{ function('get_theme_mod', 'pastor_image') }}" 
               alt="{{ function('get_theme_mod', 'pastor_name') }}" 
               class="rounded-3xl shadow-2xl w-full h-[400px] object-cover">
        {% endif %}
      </div>
      <div class="w-full md:w-2/3 text-center md:text-left">
        <h2 class="text-blue-600 font-bold uppercase tracking-widest text-sm mb-4">Leadership</h2>
        <h3 class="text-4xl font-black text-slate-900 mb-6">
          Meet Our Pastor, {{ function('get_theme_mod', 'pastor_name', 'Pastor John Doe') }}
        </h3>
        <p class="text-lg text-slate-600 leading-relaxed italic">
          {{ function('get_theme_mod', 'pastor_bio') }}
        </p>
      </div>
    </div>
  </section>

</main>
{% endblock %}