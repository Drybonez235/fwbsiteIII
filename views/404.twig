{% extends "base.twig" %}

{% block content %}
<main class="flex min-h-dvh flex-col items-center justify-center px-4 text-center">
    <div class="max-w-2xl">
        <h1 class="text-6xl font-bold text-gray-900 dark:text-white sm:text-8xl">404</h1>
        <p class="mt-4 text-xl/7 text-gray-600 dark:text-gray-300">
            The Holy Spirit is here but the page you're looking for isn't!
        </p>
        
        <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="{{ site.url }}" class="rounded-sm bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500">
                Back to Home
            </a>
            {% if theme.phone %}
                <a href="tel:{{ theme.phone }}" class="rounded-sm border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800">
                    Contact Us
                </a>
            {% endif %}
        </div>
    </div>
</main>
{% endblock %}