<header class="bg-slate-50 border-black/10 flex flex-col items-center justify-between border-b p-4 md:flex-row lg:p-6">
    
    {# Logo and Church Name Wrapper #}
    <div class="flex items-center justify-between w-full md:w-auto">
        <div class="flex items-center gap-4">
            <div class="site-logo">
                {% if custom_logo_url %}
                    <a href="{{ site.url }}">
                        <img src="{{ custom_logo_url }}" alt="{{ theme.name }}" class="h-12 w-auto">
                    </a>
                {% else %}
                    <h1 class="text-xl/7 font-bold">
                        <a href="{{ site.url }}">{{ theme.name }}</a>
                    </h1>
                {% endif %}
            </div>
            <h2 class="text-lg/6 font-semibold text-gray-800">{{ theme.name }}</h2>
        </div>
        
        {# Mobile Menu Toggle could go here if you have a full mobile menu #}
    </div>

    {# Primary Navigation #}
    <nav class="mt-4 md:mt-0 w-full md:w-auto">
        <ul class="flex flex-col md:flex-row list-none gap-4 md:gap-6">
            {% for item in menu.items %}
                <li class="group relative {{ item.classes | join(' ') }}">
                    <div class="flex items-center justify-between md:justify-start gap-1.5">
                        <a href="{{ item.link }}" class="text-base/6 !hover:text-black font-medium !text-gray-800 transition-all hover:scale-105">
                            {{ item.title }}
                        </a>
                        
                        {% if item.children %}
                            {# The "Secret" Toggle: Hidden checkbox for mobile click #}
                            <input type="checkbox" id="menu-{{ loop.index }}" class="peer hidden" />
                            
                            <label for="menu-{{ loop.index }}" class="cursor-pointer size-8 flex items-center justify-center text-gray-400 transition-transform duration-200 peer-checked:rotate-180 md:group-hover:rotate-180 md:size-3">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
                            </label>
                            
                            {# Lightweight Dropdown: Peer-checked for mobile, Group-hover for desktop #}
                            <ul class="invisible opacity-0 h-0 overflow-hidden md:h-auto md:overflow-visible absolute md:top-full left-0 z-50 mt-1 min-w-44 border border-black/5 bg-white py-1 transition-all duration-150 
                                       peer-checked:visible peer-checked:opacity-100 peer-checked:h-auto peer-checked:relative md:peer-checked:absolute
                                       md:group-hover:visible md:group-hover:opacity-100">
                                {% for child in item.children %}
                                    <li class="{{ child.classes | join(' ') }}">
                                        <a href="{{ child.link }}" class="hover:bg-slate-50 block px-4 py-2 text-sm/5 text-gray-600 hover:text-black">
                                            {{ child.title }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    </nav>
</header>