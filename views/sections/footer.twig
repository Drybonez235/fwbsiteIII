<footer class="bg-slate-50 border-t border-slate-200 py-16">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 text-slate-600">
            
            {# Column 1: Branding & Social #}
            <div class="flex flex-col gap-8">
                <div class="mx-auto">
                    {% if custom_logo_url %}
                        <a href="{{ site.url }}">
                            <img src="{{ custom_logo_url }}" alt="{{ theme.name }}" class="h-24 w-auto">
                        </a>
                    {% else %}
                        <h2 class="text-xl/8 font-bold text-slate-900">
                            <a href="{{ site.url }}">{{ theme.name }}</a>
                        </h2>
                    {% endif %}
                </div>
            </div>

            {# Column 2: Service Schedule #}
            <div class="flex flex-col gap-4">
                <h3 class="text-xs font-bold uppercase tracking-widest text-slate-900">Service Times</h3>
                <dl class="text-sm/6 flex flex-col gap-2 max-w-xs">
                    <div class="flex justify-between border-b border-slate-200 pb-1">
                        <dt>Sunday School</dt>
                        <dd class="font-bold text-slate-900">{{ theme.service.sunday_school }}</dd>
                    </div>
                    <div class="flex justify-between border-b border-slate-200 pb-1">
                        <dt>Morning Worship</dt>
                        <dd class="font-bold text-slate-900">{{ theme.service.sunday_morning }}</dd>
                    </div>
                    {% if theme.service.night_enabled %}
                    <div class="flex justify-between border-b border-slate-200 pb-1">
                        <dt>Evening Service</dt>
                        <dd class="font-bold text-slate-900">{{ theme.service.night_time }}</dd>
                    </div>
                    {% endif %}
                    {% if theme.service.wednesday_enabled %}
                    <div class="flex justify-between border-b border-slate-200 pb-1">
                        <dt>Midweek Prayer</dt>
                        <dd class="font-bold text-slate-900">{{ theme.service.wednesday_time }}</dd>
                    </div>
                    {% endif %}
                </dl>
            </div>

            {# Column 3: Contact Info #}
            <div class="flex flex-col gap-4">
                <h3 class="text-xs font-bold uppercase tracking-widest text-slate-900">Contact Us</h3>
                <div class="text-sm/6 text-slate-900">
                    <p class="font-medium">
                        <a href="tel:{{ theme.phone }}" class="hover:opacity-70 transition-opacity">
                            {{ theme.phone }}
                        </a>
                    </p>
                    <p class="font-medium mt-1">
                        <a href="mailto:{{ theme.email }}" class="hover:opacity-70 transition-opacity">
                            {{ theme.email }}
                        </a>
                    </p>
                    <address class="not-italic text-slate-500 font-normal">
                        {{ theme.address|nl2br }}
                    </address>
                   {# The parent container needs vertical alignment #}
<div class="flex items-center gap-5 mx-auto mt-4">
    {% for platform, data in theme.social %}
        {% if data.enabled and data.url %}
            <a href="{{ data.url }}" 
               target="_blank" 
               rel="noopener" 
               class="text-slate-900 hover:opacity-70 transition-opacity flex items-center justify-center"
               aria-label="{{ platform | capitalize }}">
                
                {% if platform == 'facebook' %}
                    <svg fill="currentColor" class="size-8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" data-name="Layer 1">
                        <path d="M20.9,2H3.1A1.1,1.1,0,0,0,2,3.1V20.9A1.1,1.1,0,0,0,3.1,22h9.58V14.25h-2.6v-3h2.6V9a3.64,3.64,0,0,1,3.88-4,20.26,20.26,0,0,1,2.33.12v2.7H17.3c-1.26,0-1.5.6-1.5,1.47v1.93h3l-.39,3H15.8V22h5.1A1.1,1.1,0,0,0,22,20.9V3.1A1.1,1.1,0,0,0,20.9,2Z"/>
                    </svg>
                {% elseif platform == 'instagram' %}
                    <svg class="size-7" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7.5 5C6.11929 5 5 6.11929 5 7.5C5 8.88071 6.11929 10 7.5 10C8.88071 10 10 8.88071 10 7.5C10 6.11929 8.88071 5 7.5 5Z" fill="currentColor"/>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M4.5 0C2.01472 0 0 2.01472 0 4.5V10.5C0 12.9853 2.01472 15 4.5 15H10.5C12.9853 15 15 12.9853 15 10.5V4.5C15 2.01472 12.9853 0 10.5 0H4.5ZM4 7.5C4 5.567 5.567 4 7.5 4C9.433 4 11 5.567 11 7.5C11 9.433 9.433 11 7.5 11C5.567 11 4 9.433 4 7.5ZM11 4H12V3H11V4Z" fill="currentColor"/>
                    </svg>
                {% elseif platform == 'youtube' %}
                    <svg class="size-9" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M22.54 6.42a2.765 2.765 0 0 0-1.945-1.957C18.88 4 12 4 12 4s-6.88 0-8.595.463A2.765 2.765 0 0 0 1.46 6.42C1 8.148 1 11.75 1 11.75s0 3.602.46 5.33a2.765 2.765 0 0 0 1.945 1.958C5.121 19.5 12 19.5 12 19.5s6.88 0 8.595-.462a2.765 2.765 0 0 0 1.945-1.958c.46-1.726.46-5.33.46-5.33s0-3.602-.46-5.33ZM9.75 8.479v6.542l5.75-3.271-5.75-3.271Z" fill="currentColor"/>
                    </svg>
                {% endif %}
            </a>
        {% endif %}
    {% endfor %}
</div>
                
                </div>
            </div>
        </div>
    </div>
</footer>