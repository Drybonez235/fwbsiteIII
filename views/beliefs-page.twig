{% extends "base.twig" %}

{% block content %}
{# 1. Hero Section - Increased height to min-h-[500px] #}
<header class="relative min-h-[500px] flex items-center justify-center bg-gray-900 overflow-hidden">
    {% if theme.beliefs.bg_image %}
        {# Using size-full and object-cover per v4.1 rules #}
        <img src="{{ theme.beliefs.bg_image }}" 
             class="absolute inset-0 size-full object-cover opacity-60" 
             alt="{{ theme.beliefs.title }}">
    {% endif %}
    <div class="relative text-center px-4">
        <h1 class="text-white text-5xl md:text-7xl font-bold text-shadow-lg uppercase tracking-tight">
            {{ theme.beliefs.title }}
        </h1>
    </div>
</header>

{# 2. Main Layout #}
<div class="max-w-7xl mx-auto px-4 py-20 flex flex-col md:flex-row gap-16">
    
    {# Sticky Gutter Menu - follow as you scroll #}
    <aside class="md:w-64 shrink-0">
        <nav class="sticky top-10 flex flex-col gap-1 border-l-2 border-gray-100">
            <a href="#beliefs" class="pl-6 py-3 text-lg font-bold text-gray-500 hover:text-blue-600 hover:border-l-2 hover:border-blue-600 transition-all -ml-[2px]">
                Beliefs
            </a>
            <a href="#covenant" class="pl-6 py-3 text-lg font-bold text-gray-500 hover:text-blue-600 hover:border-l-2 hover:border-blue-600 transition-all -ml-[2px]">
                Covenant
            </a>
            <a href="#affiliations" class="pl-6 py-3 text-lg font-bold text-gray-500 hover:text-blue-600 hover:border-l-2 hover:border-blue-600 transition-all -ml-[2px]">
                Affiliations
            </a>
        </nav>
    </aside>

    <main class="flex-1 min-w-0">
        
        {# Section: Beliefs #}
        <section id="beliefs" class="scroll-mt-10 mb-24">
            <details open class="group">
                {# Darker label with a dropdown arrow indicator #}
                <summary class="flex items-center justify-between p-8 bg-blue-500 text-white rounded-sm cursor-pointer list-none hover:bg-blue-600 transition-colors">
                    <span class="text-3xl font-bold">Our Beliefs</span>
                    <span class="text-4xl transition-transform duration-300 group-open:rotate-180">▾</span>
                </summary>
                
                <div class="mt-12 space-y-12">
                    {% for belief in theme.beliefs.items %}
                        {# Styled to match your reference image #}
                        <article class="border-b border-gray-300 pb-10 last:border-0">
                            <h3 class="text-2xl font-black text-gray-900 mb-6 uppercase tracking-wide">
                                {{ belief.title }}
                            </h3>
                            <p class="text-xl/9 font-bold text-gray-600 max-w-4xl">
                                {{ belief.content }}
                            </p>
                        </article>
                    {% endfor %}
                </div>
            </details>
        </section>

        {# Section: Covenant #}
        {% if theme.beliefs.covenant.enabled %}
        <section id="covenant" class="scroll-mt-10 mb-24">
            <details class="group">
                <summary class="flex items-center justify-between p-8 bg-blue-500 text-white rounded-sm cursor-pointer list-none hover:bg-blue-600 transition-colors">
                    <span class="text-3xl font-bold">Our Church Covenant</span>
                    <span class="text-4xl transition-transform duration-300 group-open:rotate-180">▾</span>
                </summary>
                <div class="mt-12 prose prose-xl max-w-none px-2 text-gray-700 font-medium">
                    {{ theme.beliefs.covenant.content|wpautop }}
                </div>
            </details>
        </section>
        {% endif %}

        {# Section: Affiliations #}
        {% if theme.beliefs.partnerships.enabled %}
        <section id="affiliations" class="scroll-mt-10">
            <details class="group">
                <summary class="flex items-center justify-between p-8 bg-blue-500 text-white rounded-sm cursor-pointer list-none hover:bg-blue-600 transition-colors">
                    <span class="text-3xl font-bold">Affiliations</span>
                    <span class="text-4xl transition-transform duration-300 group-open:rotate-180">▾</span>
                </summary>
                <div class="mt-12 grid gap-8">
                    {% for partner in theme.beliefs.partnerships.affiliations %}
                        <div class="p-8 border-l-4 border-blue-500 bg-gray-50 rounded-r-lg">
                            <h3 class="text-2xl font-bold text-gray-900">{{ partner.name }}</h3>
                            <p class="text-lg/8 text-gray-600 mt-3">{{ partner.desc }}</p>
                        </div>
                    {% endfor %}
                </div>
            </details>
        </section>
        {% endif %}

    </main>
</div>
{% endblock %}