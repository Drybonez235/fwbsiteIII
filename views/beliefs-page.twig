{% extends "base.twig" %}

{% block content %}
{# 1. Hero Section #}
<header class="relative min-h-[500px] flex items-center justify-center bg-gray-900 overflow-hidden">
    {% if theme.beliefs.bg_image %}
        {# Use size-full per v4.1 rules #}
        <img src="{{ theme.beliefs.bg_image }}" 
             class="absolute inset-0 size-full object-cover opacity-60" 
             alt="{{ theme.beliefs.title }}">
    {% endif %}
    <div class="relative text-center px-4">
        {# text-shadow-lg is now native in v4.1 #}
        <h1 class="text-white text-5xl md:text-7xl font-bold text-shadow-lg uppercase tracking-tight">
            {{ theme.beliefs.title }}
        </h1>
    </div>
</header>

{# 2. Main Layout #}
<div class="max-w-7xl mx-auto px-4 py-20 flex flex-col md:flex-row gap-16">
    
    {# Sticky Gutter Menu #}
    <aside class="md:w-64 shrink-0">
        <nav class="sticky top-10 flex flex-col gap-1 border-l-2 border-gray-100">
            {% set nav_items = [
                {'id': 'beliefs', 'label': 'Beliefs'},
                {'id': 'covenant', 'label': 'Covenant', 'show': theme.beliefs.covenant.enabled},
                {'id': 'affiliations', 'label': 'Affiliations', 'show': theme.beliefs.partnerships.enabled}
            ] %}

            {% for item in nav_items %}
                {% if item.show is not defined or item.show %}
                    <a href="#{{ item.id }}" class="pl-6 py-3 text-lg font-bold text-gray-500 hover:text-blue-600 hover:border-l-2 hover:border-blue-600 transition-all -ml-[2px]">
                        {{ item.label }}
                    </a>
                {% endif %}
            {% endfor %}
        </nav>
    </aside>

    <main class="flex-1 min-w-0">
        
        {# Section: Beliefs #}
        <section id="beliefs" class="scroll-mt-10 mb-24">
            <details open class="group">
                <summary class="flex items-center justify-between p-5 bg-slate-700 text-white rounded-sm cursor-pointer list-none hover:bg-slate-800 transition-colors">
                    <span class="text-xl font-bold tracking-tight">Our Beliefs</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" class="size-5 opacity-80 transition-transform duration-300 group-open:rotate-180">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                </summary>
                
                <div class="mt-10 flex flex-col gap-10 px-2">
                    {% for belief in theme.beliefs.items %}
                        <article class="border-b border-slate-200 pb-4 last:border-0 last:pb-0">
                            <h3 class="text-lg font-extrabold text-slate-800 mb-3 uppercase tracking-wide">
                                {{ belief.title }}
                            </h3>
                            {# Use text-base/7 for line-height per v4 rules #}
                            <p class="text-base/7 text-stone-600 max-w-3xl">
                                {{ belief.content }}
                            </p>
                        </article>
                    {% endfor %}
                </div>
            </details>
        </section>

        {# Section: Covenant #}
        {% if theme.beliefs.covenant.enabled %}
        <section id="covenant" class="scroll-mt-10 mb-24">
            <details class="group">
                <summary class="flex items-center justify-between p-5 bg-slate-700 text-white rounded-sm cursor-pointer list-none hover:bg-slate-800 transition-colors">
                    <span class="text-xl font-bold tracking-tight">Church Covenant</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height ="20" class="size-5 opacity-80 transition-transform duration-300 group-open:rotate-180">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                </summary>
                <div class="mt-10 px-2">
                    <article>
                        <h3 class="text-lg font-extrabold text-slate-800 mb-3 uppercase tracking-wide">
                            The Covenant of {{ theme.name }}
                        </h3>
                        <div class="text-base/7 text-stone-600 max-w-3xl">
                            {{ theme.beliefs.covenant.content|wpautop }}
                        </div>
                    </article>
                </div>
            </details>
        </section>
        {% endif %}

        {# Section: Affiliations #}
        {% if theme.beliefs.partnerships.enabled %}
        <section id="affiliations" class="scroll-mt-10">
            <details class="group">
                <summary class="flex items-center justify-between p-5 bg-slate-700 text-white rounded-sm cursor-pointer list-none hover:bg-slate-800 transition-colors">
                    <span class="text-xl font-bold tracking-tight">Church Affiliations</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"  width="20" height ="20" class="size-5 opacity-80 transition-transform duration-300 group-open:rotate-180">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                </summary>
                {# Grid Container: 3 Cols on Desktop with minimal dividers #}
                <div class="mt-10 grid grid-cols-1  gap-y-10 md:divide-x divide-slate-200 px-2">
                    {% for partner in theme.beliefs.partnerships.affiliations %}
                            <div class="border-b border-slate-200 pb-4 last:border-0 last:pb-0">
                            <h3 class="text-lg font-extrabold text-slate-800 mb-3 uppercase tracking-wide">
                                {{ partner.name }}
                            </h3>
                            {# Use text-base/7 for line-height per v4 rules #}
                            <p class="text-base/7 text-stone-600 max-w-3xl">
                                {{ partner.desc }}
                            </p>
                        </div>
                       
                    {% endfor %}
                </div>
            </details>
        </section>
        {% endif %}

    </main>
</div>
{% endblock %}