{% extends "base.twig" %}

{% block content %}
<main class="max-w-4xl mx-auto py-12 px-6">
    {% if posts %}
        {% for post in posts %}
            <article class="mb-12">
                <h2 class="text-3xl font-black text-slate-900 mb-4 tracking-tight">
                    <a href="{{ post.link }}" class="hover:text-blue-600 transition-colors">
                        {{ post.title }}
                    </a>
                </h2>
                <div class="prose prose-slate max-w-none">
                    {{ post.content }}
                </div>
            </article>
        {% endfor %}
    {% else %}
        <p class="text-slate-500 italic">No content found.</p>
    {% endif %}
</main>
{% endblock %}