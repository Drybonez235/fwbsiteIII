{% extends "base.twig" %}

{% block content %}
<main id="main-content" class="bg-stone-50">

  {# --- Hero Section --- #}
  <section class="relative">
    {# v4 Tip: Using min-h-dvh for better mobile Safari support #}
    <div class="h-[500px] bg-cover bg-center flex items-center justify-center relative" 
         style="background-image: url('{{ theme.image }}');">
      <div class="absolute inset-0 bg-black/30"></div> {# Lightened Overlay #}
      <div class="relative z-10 text-center text-white px-6">
        <h1 class="text-blue-gray-50! text-5xl md:text-7xl font-serif tracking-tight text-shadow-sm">
          {{ theme.name }}
        </h1>
      </div>
    </div>

    {# --- Info Bar (Neutral Stone/Slate) --- #}
    <div class="bg-slate-800 text-stone-100 py-6 border-b border-stone-200">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex flex-col md:flex-row gap-4 md:gap-12 text-center md:text-left">
          <p class="text-sm/6 font-medium uppercase tracking-wide">Sunday School <span class="block text-xl font-bold text-white">{{ theme.service.sunday_school }}</span></p>
          <p class="text-sm/6 font-medium uppercase tracking-wide">Worship <span class="block text-xl font-bold text-white">{{ theme.service.sunday_morning }}</span></p>
        </div>
        <div class="text-center md:text-right">
          <p class="text-xl font-bold text-white">{{ theme.phone }}</p>
          <p class="text-sm/6 text-stone-300">{{ theme.address }}</p>
        </div>
      </div>
    </div>
  </section>

  {# --- Mission Statement (Classic Typography) --- #}
  <section class="py-24 bg-white border-b border-stone-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <blockquote class="mb-12">
        <p class="text-2xl md:text-3xl/relaxed font-serif italic text-slate-700">
          "{{ theme.mission_statement }}"
        </p>
        <footer class="mt-8 text-slate-500 font-medium tracking-widest uppercase text-xs">
          — {{ theme.mission_subtext }}
        </footer>
      </blockquote>
      <a href="/about-us" class="inline-block border border-slate-800 text-slate-800 px-10 py-3 rounded-sm font-bold hover:bg-slate-600 hover:text-white transition-colors duration-300">
        Our Beliefs & History
      </a>
    </div>
  </section>

  {# --- Service Times Section --- #}
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      
      {# Main Sunday Hero (Softened) #}
      <div class="relative rounded-sm overflow-hidden mb-12 border border-stone-200 min-h-[450px] flex items-end">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ theme.service.image }}');"></div>
        <div class="absolute inset-0 bg-linear-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
        
        <div class="relative p-8 md:p-16 text-white w-full">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-blue-grey-300 mb-4">Worship with us</h2>
          <h3 class="text-4xl md:text-5xl font-serif mb-6">Sunday Worship</h3>
          <div class="flex flex-col md:flex-row md:items-center gap-6">
             <span class="inline-block border border-stone-400 px-6 py-2 text-2xl font-light">
               {{ theme.service.sunday_morning }}
             </span>
             <p class="max-w-xl text-stone-200 text-lg/7 font-light italic">
               {{ theme.service.message }}
             </p>
          </div>
        </div>
      </div>

      {# Secondary Service Grid #}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-stone-200 border border-stone-200">
        
        {# Sunday School Card #}
        <div class="bg-white p-8 flex flex-col justify-between min-h-48">
          <div>
            <h4 class="font-bold text-slate-800 uppercase text-xs tracking-widest mb-4">Sunday School</h4>
            <p class="text-slate-500 text-sm/6 mb-6">{{ theme.service.sunday_school_desc }}</p>
          </div>
          <span class="text-2xl font-serif text-slate-900">{{ theme.service.sunday_school }}</span>
        </div>

        {# Sunday Service Card #}
        <div class="bg-white p-8 flex flex-col justify-between min-h-48">
          <div>
            <h4 class="font-bold text-slate-800 uppercase text-xs tracking-widest mb-4">Morning Service</h4>
            <p class="text-slate-500 text-sm/6 mb-6">{{ theme.service.sunday_morning_desc }}</p>
          </div>
          <span class="text-2xl font-serif text-slate-900">{{ theme.service.sunday_morning }}</span>
        </div>

        {# Sunday Night Card #}
        {% if theme.service.night_enabled %}
        <div class="bg-white p-8 flex flex-col justify-between min-h-48">
          <div>
            <h4 class="font-bold text-slate-800 uppercase text-xs tracking-widest mb-4">Evening Service</h4>
            <p class="text-slate-500 text-sm/6 mb-6">A traditional close to the Lord's Day.</p>
          </div>
          <span class="text-2xl font-serif text-slate-900">{{ theme.service.night_time }}</span>
        </div>
        {% endif %}

        {# Wednesday Night Card #}
        {% if theme.service.wednesday_enabled %}
        <div class="bg-white p-8 flex flex-col justify-between min-h-48">
          <div>
            <h4 class="font-bold text-slate-800 uppercase text-xs tracking-widest mb-4">Midweek Prayer</h4>
            <p class="text-slate-500 text-sm/6 mb-6">Bible study and corporate prayer.</p>
          </div>
          <span class="text-2xl font-serif text-slate-900">{{ theme.service.wednesday_time }}</span>
        </div>
        {% endif %}

      </div>
    </div>
  </section>

  {# --- Pastor Section (Traditional Layout) --- #}
  <section class="py-24 bg-stone-100 px-6 border-t border-stone-200">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="w-full md:w-2/5">
        {% if theme.pastor.image %}
          <img src="{{ theme.pastor.image }}" 
               alt="{{ theme.pastor.name }}" 
               class="rounded-sm shadow-sm border-8 border-white w-full h-[450px] object-cover">
        {% endif %}
      </div>
      <div class="w-full md:w-3/5 text-center md:text-left">
        <h2 class="text-slate-500 font-bold uppercase tracking-[0.2em] text-xs mb-4">Our Leadership</h2>
        <h3 class="text-4xl font-serif text-slate-900 mb-8">
          {{ theme.pastor.name }}
        </h3>
        <div class="relative">
          <span class="absolute -top-6 -left-4 text-6xl text-stone-300 font-serif">“</span>
          <p class="text-lg/8 text-slate-600 italic relative z-10">
            {{ theme.pastor.bio }}
          </p>
        </div>
      </div>
    </div>
  </section>

</main>
{% endblock %}