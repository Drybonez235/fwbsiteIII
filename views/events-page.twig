{% extends "base.twig" %}

{% block content %}
{# Container focused on a single column with a max-width for readability #}
<section class="mx-auto flex max-w-4xl flex-col gap-10">
    {% for event in theme.events %}
        <div class="flex flex-col overflow-hidden rounded-sm bg-white shadow-sm md:flex-row">
            {# Image Section - Fixed aspect ratio #}
            {% if event.image %}
                <div class="md:w-1/3">
                    <img src="{{ event.image }}" alt="{{ event.title }}" class="aspect-video size-full object-cover md:aspect-square">
                </div>
            {% endif %}
            
            {# Content Section #}
            <div class="flex flex-col justify-center p-6 md:w-2/3">
                <h3 class="text-xl/7 font-bold text-gray-900">{{ event.title }}</h3>
                
                <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
                    <p class="text-sm/6 font-semibold text-blue-600">{{ event.date }}</p>
                    <p class="text-sm/6 text-gray-500">{{ event.location }}</p>
                </div>
                
                {% if event.description %}
                    <p class="mt-4 text-base/6 text-gray-700">{{ event.description }}</p>
                {% endif %}
            </div>
        </div>
    {% else %}
        <p class="text-center text-lg/7 text-gray-500">No upcoming events scheduled at this time.</p>
    {% endfor %}
</section>
{% endblock %}